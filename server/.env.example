# ==========================================
# LexisAI Backend - Environment Configuration
# ==========================================
# DO NOT ADD SECRETS TO THIS FILE
# Copy this file to .env and replace the values

# ------------------------------------------
# 1. Server Configuration
# ------------------------------------------
NODE_ENV="development" # development | production | test
PORT=5000
API_VERSION="v1"
FRONTEND_URL="http://localhost:5173"

# ------------------------------------------
# 2. Database (Neon PostgreSQL & Prisma)
# ------------------------------------------
# Format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://user:password@ep-wandering-water-a5qg9z.us-east-2.aws.neon.tech/lexisai?sslmode=require"

# ------------------------------------------
# 3. Authentication (JWT)
# ------------------------------------------
# Generate secure keys using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="your_super_secret_access_token_key_here"
JWT_REFRESH_SECRET="your_super_secret_refresh_token_key_here"
JWT_ACCESS_EXPIRES_IN="15m"  # e.g., 15m, 1h
JWT_REFRESH_EXPIRES_IN="7d"  # e.g., 7d, 30d

# ------------------------------------------
# 4. Redis & Background Jobs (BullMQ)
# ------------------------------------------
REDIS_URL="redis://localhost:6379"
# REDIS_HOST="localhost"
# REDIS_PORT=6379
# REDIS_PASSWORD=""

# ------------------------------------------
# 5. File Storage (AWS S3)
# ------------------------------------------
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="lexisai-production-documents"

# ------------------------------------------
# 6. Artificial Intelligence (OpenAI)
# ------------------------------------------
OPENAI_API_KEY="sk-your_openai_api_key_here"
OPENAI_MODEL="gpt-4o" # default model for AI tasks

# ------------------------------------------
# 7. Logging & Metrics
# ------------------------------------------
LOG_LEVEL="info" # debug | info | warn | error

# ------------------------------------------
# 8. Security & Rate Limiting
# ------------------------------------------
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes (in milliseconds)
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per window
