generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  LAWYER
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  firstName        String?
  lastName         String?
  role             Role     @default(USER)
  avatar           String?
  organizationName String?
  phoneNumber      String?
  
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?

  cases     Case[]   @relation("ClientCases")
  lawyerCases Case[] @relation("LawyerCases")
  payments  Payment[]
  messages  Message[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@map("users")
}

model Case {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      CaseStatus @default(OPEN)
  
  clientId    String
  client      User       @relation("ClientCases", fields: [clientId], references: [id])
  
  lawyerId    String?
  lawyer      User?      @relation("LawyerCases", fields: [lawyerId], references: [id])
  
  documents   Document[]
  hearings    Hearing[]
  messages    Message[]
  tasks       Task[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([clientId])
  @@index([lawyerId])
  @@index([status])
  @@map("cases")
}

model Document {
  id          String   @id @default(uuid())
  fileName    String
  fileUrl     String
  fileType    String
  fileSize    Int
  
  metadata    Json?    // AI summary, OCR data
  
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  
  uploadedBy  String
  
  chunks      DocumentChunk[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([caseId])
  @@map("documents")
}

model DocumentChunk {
  id          String   @id @default(uuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  textContent String
  embedding   Json     // float array
  createdAt   DateTime @default(now())

  @@index([documentId])
  @@map("document_chunks")
}

model Hearing {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime
  location  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@map("hearings")
}

model Message {
  id        String   @id @default(uuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([senderId])
  @@map("messages")
}

model Task {
  id           String     @id @default(uuid())
  caseId       String
  case         Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedToId String?
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([caseId])
  @@map("tasks")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("audit_logs")
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String   @unique
  paymentId     String?
  signature     String?
  amount        Int      // stored in paise (1 INR = 100 paise)
  currency      String   @default("INR")
  status        String   // 'PENDING' | 'SUCCESS' | 'FAILED'
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("payments")
}
